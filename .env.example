# Application
PORT=3333

# Database (PostgreSQL)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=change_postgres_password
POSTGRES_NAME=claude_code_nestjs

# Database (MySQL)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USERNAME=developer
MYSQL_PASSWORD=change_mysql_password
MYSQL_DATABASE=claude_code_nestjs

# AdventureWorks (Microsoft SQL Server, read-only account recommended)
MSSQL_HOST=server.example.com
MSSQL_PORT=1433
MSSQL_USERNAME=change_mssql_username
MSSQL_PASSWORD=change_mssql_password
MSSQL_DATABASE=AdventureWorks

# MongoDB
MONGODB_URI=mongodb://root:change_mongodb_password@127.0.0.1:27017/claude_code_nestjs?authSource=admin

# Redis (for Bull queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_redis_password

# Cache
CACHE_TTL=3600000
CACHE_MAX_SIZE=100

# Request throttling
THROTTLE_TTL=1000
THROTTLE_LIMIT=10

# Authentication
OTP_EXPIRES_IN=300
JWT_SECRET=change_jwt_secret
JWT_EXPIRES_IN=1y
JWT_REFRESH_EXPIRES_IN=10y
LOGIN_ATTEMPTS_TIMEOUT=10000
LOGIN_ATTEMPTS_MAX=5
X_API_KEY=change_api_key
HTTP_BASIC_USERNAME=change_http_basic_username
HTTP_BASIC_PASSWORD=change_http_basic_password

# Logging
DB_LOGGING=false
LOG_DB_ENABLED=false
LOG_HTTP_ENABLED=true
LOG_HTTP_EXCEPTION_ENABLED=false

# AWS SES (Email service)
AWS_SES_REGION=ap-southeast-1
AWS_SES_ACCESS_KEY_ID=change_aws_ses_access_key_id
AWS_SES_SECRET_ACCESS_KEY=change_aws_ses_secret_access_key

# AWS S3 (Object storage)
AWS_S3_ACCESS_KEY_ID=change_aws_s3_access_key_id
AWS_S3_SECRET_ACCESS_KEY=change_aws_s3_secret_access_key
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=change_aws_s3_bucket
