# Application
PORT=3333

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres_password
DB_NAME=claude_code_nestjs

# MongoDB
MONGODB_URI=mongodb://localhost:27017/claude_code_nestjs

# Redis (for Bull queue)
# If Redis is running without password, leave REDIS_PASSWORD empty or comment it out
# If Redis requires authentication, set the correct password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS SES (Email service)
AWS_SES_REGION=ap-southeast-1
AWS_SES_ACCESS_KEY_ID=your_access_key_id
AWS_SES_SECRET_ACCESS_KEY=your_secret_access_key
